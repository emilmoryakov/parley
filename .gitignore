# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# vite (legacy A4 build output, if regenerated)
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
#   .env       — committed: holds the non-secret DATABASE_URL so the app runs after clone
#   .env.local — gitignored: holds secrets (OPENROUTER_API_KEY)
.env.local
.env*.local

# SQLite database (regenerated via `prisma migrate dev` + `npm run db:seed`)
/dev.db*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# legacy A3 secret (the old plain-JS key file)
config.js

# generated Prisma client
/src/generated/prisma
