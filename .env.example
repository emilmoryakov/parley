# Copy this file to `.env.local` and paste in your own OpenRouter key.
# `.env.local` is gitignored, so the key never gets committed.
# Grab a key at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Optional — any OpenRouter model id. Defaults to openai/gpt-4o-mini.
# Browse ids at https://openrouter.ai/models
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini
