# Copy this file to `.env.local` and paste in your OpenRouter key.
#
# This key is read ONLY on the server (src/app/api/chat/route.ts via
# process.env). It has no NEXT_PUBLIC_ prefix, so Next.js never ships it to the
# browser. `.env.local` is gitignored, so the key is never committed.
#
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — any OpenRouter model id. Defaults to openai/gpt-4o-mini.
# Browse ids at https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini
